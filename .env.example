# Base URL do backend que o front (Vite) chama em /format.
#
# Vazio  = mesma origem (caminho relativo /format) — uso em PRODUÇÃO, com o
#          front servido atrás de um proxy reverso que encaminha /format ao backend.
# Em DEV = aponte para o backend local, ex.:
#
#   VITE_API_URL=http://localhost:3000
#
# Copie este arquivo para .env (ou .env.local, que já é ignorado pelo git) e ajuste.
VITE_API_URL=
